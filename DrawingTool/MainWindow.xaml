<Window x:Class="DrawingTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Drawing Tool - Advanced Wire Routing" Height="700" Width="1050"
        KeyDown="Window_KeyDown">
    <DockPanel>
        <ToolBar DockPanel.Dock="Top" Padding="10,5" Background="#EEEEEE">
            <TextBlock Text="操作モード:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <RadioButton Content="選択 / 移動 / 変形" Name="rbSelect" IsChecked="True" Margin="5"/>
            <RadioButton Content="図形の描画 (配置)" Name="rbDraw" Margin="20,5,5,5"/>
            <Separator/>
            <Button Content="開く" Click="BtnOpen_Click" Padding="12,3" Margin="10,0,0,0"/>
            <Button Content="保存" Click="BtnSave_Click" Padding="12,3" Margin="10,0,0,0"/>
            <Button Content="CSV出力" Click="BtnExportCsv_Click" Padding="12,3" Margin="10,0,0,0"/>
            <Button Content="選択図形を削除" Click="BtnDeleteSelected_Click" Padding="12,3" Margin="10,0,0,0"/>
        </ToolBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="300" MinWidth="220"/>
            </Grid.ColumnDefinitions>

        <TabControl Name="RightTabControl" Grid.Column="2" Margin="5">
            <TabItem Header="図形選択">
                <DockPanel Margin="5">
                    <TextBlock Text="描画する図形（マスター）を選択：" DockPanel.Dock="Top" Margin="0,0,0,5"/>
                    <ListBox Name="lstShapes"
                             ItemsSource="{Binding RegisteredShapes}"
                             SelectedItem="{Binding SelectedShape, Mode=TwoWay}"
                             DisplayMemberPath="DisplayText"/>
                </DockPanel>
            </TabItem>

            <TabItem Header="シンボル一覧">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="定義済みシンボル（入力・登録したマスター）："
                               Margin="0,0,0,5"
                               FontWeight="Bold"/>
                    <ListBox Grid.Row="1"
                             Name="lstRegisteredSymbols"
                             ItemsSource="{Binding RegisteredSymbols}"
                             SelectedItem="{Binding SelectedRegisteredSymbol, Mode=TwoWay}"
                             DisplayMemberPath="DisplayText"
                             SelectionChanged="LstRegisteredSymbols_SelectionChanged"/>

                    <TextBlock Grid.Row="2"
                               Text="現在編集中のデータに配置済みの図形："
                               Margin="0,10,0,5"
                               FontWeight="Bold"/>
                    <ListBox Grid.Row="3"
                             Name="lstPlacedSymbols"
                             ItemsSource="{Binding PlacedSymbols}"
                             DisplayMemberPath="DisplayText"
                             SelectionChanged="LstPlacedSymbols_SelectionChanged"/>

                    <TextBlock Grid.Row="4"
                               Text="選択した配置済み図形の対応情報:"
                               Margin="0,10,0,5"
                               FontWeight="Bold"/>
                    <StackPanel Grid.Row="5">
                        <ComboBox Name="cmbPlacedSymbolDataDefinition"
                                  ItemsSource="{Binding DataDefinitions}"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="CmbPlacedSymbolDataDefinition_SelectionChanged"
                                  Margin="0,0,0,5"
                                  Padding="2"/>
                        <ComboBox Name="cmbPlacedDataRecord"
                                  DisplayMemberPath="DisplayText"
                                  Margin="0,0,0,5"
                                  Padding="2"/>
                        <Button Content="追加データを対応情報へ割付"
                                Click="BtnAssignDataRecordToPlaced_Click"
                                Padding="6,2"
                                Margin="0,0,0,5"/>
                        <TextBlock Text="割付済み対応情報:" Margin="0,0,0,2"/>
                        <TextBox Name="txtPlacedSymbolAttributes"
                                 Height="90"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,5"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="線グループ">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="グループ化対象の線グループ:"
                               Margin="0,0,0,5"
                               FontWeight="Bold"/>
                    <ListBox Grid.Row="1"
                             Name="lstLineGroups"
                             ItemsSource="{Binding LineGroups}"
                             DisplayMemberPath="DisplayText"
                             SelectionChanged="LstLineGroups_SelectionChanged"/>

                    <TextBlock Grid.Row="2"
                               Text="選択した線グループの対応情報:"
                               Margin="0,10,0,5"
                               FontWeight="Bold"/>
                    <StackPanel Grid.Row="3">
                        <ComboBox Name="cmbLineGroupDataDefinition"
                                  ItemsSource="{Binding DataDefinitions}"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="CmbLineGroupDataDefinition_SelectionChanged"
                                  Margin="0,0,0,5"
                                  Padding="2"/>
                        <ComboBox Name="cmbLineGroupDataRecord"
                                  DisplayMemberPath="DisplayText"
                                  Margin="0,0,0,5"
                                  Padding="2"/>
                        <Button Content="追加データを線グループへ割付"
                                Click="BtnAssignDataRecordToLineGroup_Click"
                                Padding="6,2"
                                Margin="0,0,0,5"/>
                        <Button Content="線グループデータを自動作成"
                                Click="BtnAutoCreateLineGroupData_Click"
                                Padding="6,2"
                                Margin="0,0,0,5"/>
                        <TextBlock Text="割付済み対応情報:" Margin="0,0,0,2"/>
                        <TextBox Name="txtLineGroupAttributes"
                                 Height="90"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,5"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="シグナル">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="110"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="開始図形:" FontWeight="Bold" Margin="0,0,0,3"/>
                        <ComboBox Name="cmbSignalStartItem"
                                  ItemsSource="{Binding PlacedSymbols}"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="CmbSignalStartItem_SelectionChanged"
                                  Padding="2"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock Text="シグナル名:" Margin="0,0,0,3"/>
                        <TextBox Name="txtSignalName" Text="signal" Padding="2" Margin="0,0,0,5"/>
                        <CheckBox Name="chkSignalAllPorts"
                                  Content="全てのポートから発信する"
                                  IsChecked="True"
                                  Margin="0,0,0,5"/>
                        <TextBlock Text="発信ポートID:" Margin="0,0,0,3"/>
                        <ComboBox Name="cmbSignalStartPort"
                                  IsEditable="True"
                                  Padding="2"
                                  Margin="0,0,0,5"/>
                        <TextBlock Text="最大伝搬ステップ:" Margin="0,0,0,3"/>
                        <TextBox Name="txtSignalMaxSteps" Text="50" Padding="2"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="選択中図形から送信"
                                Click="BtnRunSignalFromSelected_Click"
                                Padding="6,2"
                                Margin="0,0,6,0"/>
                        <Button Content="開始図形から送信"
                                Click="BtnRunSignalFromList_Click"
                                Padding="6,2"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="シグナルを保存"
                                Click="BtnSaveSignalSettings_Click"
                                Padding="6,2"
                                Margin="0,0,6,0"/>
                        <Button Content="選択シグナルを読込"
                                Click="BtnLoadSignalSettings_Click"
                                Padding="6,2"
                                Margin="0,0,6,0"/>
                        <Button Content="選択シグナルを削除"
                                Click="BtnDeleteSignalSettings_Click"
                                Padding="6,2"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,0,0,8">
                        <TextBlock Text="シグナルリスト:" FontWeight="Bold" Margin="0,0,0,3"/>
                        <ListBox Name="lstSavedSignals"
                                 DisplayMemberPath="DisplayText"/>
                    </StackPanel>

                    <StackPanel Grid.Row="5" Margin="0,0,0,8">
                        <TextBlock Text="受信側Python処理:" FontWeight="Bold" Margin="0,0,0,3"/>
                        <TextBox Name="txtSignalHandlerCode"
                                 Height="110"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Text="def handle_signal(signal, item, context):&#x0a;    emit_message(f&quot;{item.get('definition_id', '')} が {signal.get('name', '')} を受信&quot;)&#x0a;    return [signal]"/>
                    </StackPanel>

                    <TextBox Grid.Row="6"
                             Name="txtSignalLog"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>
                </Grid>
            </TabItem>

            <TabItem Header="CSV一覧">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="CSVテーブル一覧:" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="更新" Click="BtnRefreshCsvTables_Click" Padding="6,2" Margin="8,0,0,0"/>
                    </StackPanel>
                    <ListBox Grid.Row="1"
                             Name="lstCsvTables"
                             SelectionChanged="LstCsvTables_SelectionChanged"/>

                    <TextBlock Grid.Row="2"
                               Text="選択テーブルの列一覧:"
                               FontWeight="Bold"
                               Margin="0,10,0,5"/>
                    <ListBox Grid.Row="3"
                             Name="lstCsvColumns"/>
                    <TextBlock Grid.Row="4"
                               Text="選択テーブルの中身:"
                               FontWeight="Bold"
                               Margin="0,10,0,5"/>
                    <DataGrid Grid.Row="5"
                              Name="gridCsvPreview"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"/>
                </Grid>
            </TabItem>
            
            <TabItem Header="図形定義">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="新規図形の定義" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="図形番号 (ID):" Margin="0,0,0,2"/>
                        <TextBox Name="txtShapeId" Text="LINE-WIRE-B" Margin="0,0,0,10" Padding="2"/>

                        <TextBlock Text="種類:" Margin="0,0,0,2"/>
                        <ComboBox Name="cmbShapeType" SelectedIndex="0" Margin="0,0,0,10" Padding="2" SelectionChanged="CmbShapeType_SelectionChanged">
                            <ComboBoxItem Content="線分" Tag="Line"/>
                            <ComboBoxItem Content="四角形" Tag="Rectangle"/>
                            <ComboBoxItem Content="シンボル" Tag="Symbol"/>
                        </ComboBox>

                        <StackPanel Name="LineSettings" Visibility="Visible" Margin="0,0,0,15" Background="#FFF5F5">
                            <TextBlock Text="線分の役割（タイプ）:" FontWeight="Bold" Margin="5,5,0,5"/>
                            <RadioButton Name="rbLineNormal" Content="通常の線分 (スナップなし)" IsChecked="True" Margin="10,2,5,2"/>
                            <RadioButton Name="rbLineWireA" Content="接続線A (ポートやバスに吸着)" Foreground="Blue" Margin="10,2,5,2"/>
                            <RadioButton Name="rbLineWireB" Content="接続線B (Aの条件＋他の接続線Bにも吸着)" Foreground="DeepPink" Margin="10,2,5,2"/>
                            <RadioButton Name="rbLineWireC" Content="接続線C (線に結合して相手線を分割)" Foreground="DarkCyan" Margin="10,2,5,2"/>
                            <RadioButton Name="rbLineBus" Content="バス (中途への接続を受け入れる)" Foreground="Purple" Margin="10,2,5,5"/>
                            <CheckBox Name="chkLineGroupTarget" Content="同種接続線のグループ化対象にする" Margin="10,6,5,5"/>
                            <TextBlock Text="線グループ用データ定義:" Margin="10,6,5,2"/>
                            <ComboBox Name="cmbShapeLineGroupDataDefinition"
                                      ItemsSource="{Binding DataDefinitions}"
                                      DisplayMemberPath="DisplayText"
                                      Margin="10,0,5,4"
                                      Padding="2"/>
                            <CheckBox Name="chkAutoCreateLineGroupData"
                                      Content="線グループができた瞬間にデータを自動作成する"
                                      Margin="10,2,5,5"/>
                        </StackPanel>

                        <StackPanel Name="SymbolSettings" Visibility="Collapsed">
                            <TextBlock Text="シンボル幅（グリッド数）:" Margin="0,0,0,2"/>
                            <TextBox Name="txtSymbolGridCount" Text="3" Margin="0,0,0,4" Padding="2" TextChanged="TxtSymbolGridCount_TextChanged"/>
                            <TextBlock Text="シンボル高さ（グリッド数）:" Margin="0,0,0,2"/>
                            <TextBox Name="txtSymbolGridHeightCount" Text="2" Margin="0,0,0,4" Padding="2" TextChanged="TxtSymbolGridCount_TextChanged"/>
                            <TextBlock Text="例: 幅3・高さ2 → 60px × 40px" FontSize="10" Margin="0,0,0,10" Foreground="Gray"/>

                            <TextBlock Text="シンボル編集:" Margin="0,0,0,5" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <RadioButton Name="rbEditorPorts" Content="接続点" IsChecked="True" Margin="0,0,10,0"/>
                                <RadioButton Name="rbEditorVector" Content="ベクター描画" Margin="0,0,10,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="次のポートID:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox Name="txtNextPortId" Text="P1" Width="80" Padding="2"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <ComboBox Name="cmbVectorShape" SelectedIndex="0" Width="90" Padding="2">
                                    <ComboBoxItem Content="線" Tag="Line"/>
                                    <ComboBoxItem Content="四角" Tag="Rectangle"/>
                                    <ComboBoxItem Content="楕円" Tag="Ellipse"/>
                                </ComboBox>
                                <Button Content="最後を削除" Click="BtnUndoVector_Click" Padding="6,2" Margin="5,0,0,0"/>
                                <Button Content="絵をクリア" Click="BtnClearVector_Click" Padding="6,2" Margin="5,0,0,0"/>
                            </StackPanel>
                            <Border BorderBrush="Gray" BorderThickness="1" HorizontalAlignment="Left" Background="White">
                                <Canvas Name="EditorCanvas"
                                        Width="160"
                                        Height="160"
                                        MouseLeftButtonDown="EditorCanvas_MouseLeftButtonDown"
                                        MouseMove="EditorCanvas_MouseMove"
                                        MouseLeftButtonUp="EditorCanvas_MouseLeftButtonUp"/>
                            </Border>
                            <TextBlock Text="※接続点: クリックで追加/削除。追加時は「次のポートID」を使用。ベクター: ドラッグで線・四角・楕円を描画。" FontSize="10" Margin="0,5,0,15" Foreground="Gray" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="この図形をマスターに登録" Click="BtnRegisterShape_Click" Padding="8" Background="#E0F0FF"/>
                            <Button Content="選択図形を読み込み" Click="BtnLoadSelectedShapeDefinition_Click" Padding="8" Margin="5,0,0,0"/>
                            <Button Content="選択図形を更新" Click="BtnUpdateSelectedShapeDefinition_Click" Padding="8" Margin="5,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="データ定義">
                <DockPanel Margin="10">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="データ定義名:" Margin="0,0,0,2"/>
                        <TextBox Name="txtDataDefinitionName" Margin="0,0,0,8" Padding="2"/>

                        <TextBlock Text="親データ定義:" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ComboBox Name="cmbParentDataDefinition"
                                      Width="170"
                                      ItemsSource="{Binding DataDefinitions}"
                                      DisplayMemberPath="DisplayText"
                                      Padding="2"/>
                            <Button Content="親なし" Click="BtnClearParentDataDefinition_Click" Padding="6,2" Margin="5,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="項目名:" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBox Name="txtDataItemName" Width="170" Padding="2"/>
                            <Button Content="項目追加" Click="BtnAddDataItem_Click" Padding="6,2" Margin="5,0,0,0"/>
                        </StackPanel>
                        <CheckBox Name="chkDataItemIsReference"
                                  Content="この項目は他データのID"
                                  Margin="0,0,0,4"/>
                        <TextBlock Text="参照先データ定義:" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ComboBox Name="cmbDataItemReferenceDefinition"
                                      Width="170"
                                      ItemsSource="{Binding DataDefinitions}"
                                      DisplayMemberPath="DisplayText"
                                      Padding="2"/>
                            <Button Content="参照なし" Click="BtnClearDataItemReferenceDefinition_Click" Padding="6,2" Margin="5,0,0,0"/>
                        </StackPanel>
                        <CheckBox Name="chkUsePythonValueGenerator"
                                  Content="この項目をPythonで自動設定する"
                                  Margin="0,0,0,4"/>
                        <TextBlock Text="項目Pythonコード: generate_value(input, tables, context) を定義してください。戻り値は文字列または {'value': '...'} です。"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,2"/>
                        <TextBox Name="txtPythonValueGeneratorCode"
                                 Height="90"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 FontFamily="Consolas"
                                 Margin="0,0,0,8"
                                 Padding="2"/>

                        <ListBox Name="lstTempDataItems"
                                 Height="100"
                                 ItemsSource="{Binding TempDataItems}"
                                 DisplayMemberPath="DisplayText"
                                 SelectionChanged="LstTempDataItems_SelectionChanged"
                                 Margin="0,0,0,8"/>

                        <TextBlock Text="ID項目:" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ComboBox Name="cmbDataDefinitionIdItem"
                                      Width="170"
                                      ItemsSource="{Binding TempDataItems}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Name"
                                      Padding="2"/>
                        </StackPanel>

                        <CheckBox Name="chkUsePythonIdGenerator"
                                  Content="IDをPythonで自動採番する"
                                  Margin="0,0,0,6"/>
                        <TextBlock Text="Pythonコード: generate_id(input, tables, context) を定義してください。戻り値は文字列または {'id': '...'} です。"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,2"/>
                        <TextBox Name="txtPythonIdGeneratorCode"
                                 Height="120"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 FontFamily="Consolas"
                                 Margin="0,0,0,8"
                                 Padding="2"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="選択項目を削除" Click="BtnRemoveDataItem_Click" Padding="6,2"/>
                            <Button Content="選択項目を変更" Click="BtnUpdateDataItem_Click" Padding="6,2" Margin="5,0,0,0"/>
                            <Button Content="項目クリア" Click="BtnClearDataItems_Click" Padding="6,2" Margin="5,0,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="データ定義を登録" Click="BtnRegisterDataDefinition_Click" Padding="6,2"/>
                            <Button Content="選択定義を読み込み" Click="BtnLoadDataDefinition_Click" Padding="6,2" Margin="5,0,0,0"/>
                            <Button Content="選択定義を更新" Click="BtnUpdateDataDefinition_Click" Padding="6,2" Margin="5,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="登録済みデータ定義:" FontWeight="Bold" Margin="0,0,0,5"/>
                    </StackPanel>

                    <ListBox Name="lstDataDefinitions"
                             ItemsSource="{Binding DataDefinitions}"
                             SelectedItem="{Binding SelectedDataDefinition, Mode=TwoWay}"
                             DisplayMemberPath="DisplayText"/>
                </DockPanel>
            </TabItem>

            <TabItem Header="データ入力">
                <DockPanel Margin="10">
                    <StackPanel DockPanel.Dock="Top">
                        <ComboBox Name="cmbRecordDataDefinition"
                                  ItemsSource="{Binding DataDefinitions}"
                                  DisplayMemberPath="DisplayText"
                                  SelectedItem="{Binding SelectedDataDefinition, Mode=TwoWay}"
                                  SelectionChanged="CmbRecordDataDefinition_SelectionChanged"
                                  Margin="0,0,0,5"
                                  Padding="2"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <Button Content="定義項目から値欄を作成" Click="BtnCreateRecordFields_Click" Padding="6,2"/>
                            <Button Content="PythonでID採番" Click="BtnGenerateDataRecordId_Click" Padding="6,2" Margin="5,0,0,0"/>
                        </StackPanel>
                        <Button Content="Pythonで項目自動設定" Click="BtnGenerateDataRecordValues_Click" Padding="6,2" Margin="0,0,0,5"/>
                        <ScrollViewer Height="140"
                                      VerticalScrollBarVisibility="Auto"
                                      Margin="0,0,0,5">
                            <StackPanel Name="pnlDataRecordFields"/>
                        </ScrollViewer>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="追加データを登録" Click="BtnRegisterDataRecord_Click" Padding="6,2"/>
                            <Button Content="選択データを読込" Click="BtnLoadDataRecord_Click" Padding="6,2" Margin="5,0,0,0"/>
                            <Button Content="選択データを更新" Click="BtnUpdateDataRecord_Click" Padding="6,2" Margin="5,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="登録済み追加データ:" FontWeight="Bold" Margin="0,0,0,5"/>
                    </StackPanel>

                    <ListBox Name="lstDataRecords"
                             ItemsSource="{Binding DataRecords}"
                             SelectedItem="{Binding SelectedDataRecord, Mode=TwoWay}"
                             DisplayMemberPath="DisplayText"/>
                </DockPanel>
            </TabItem>
        </TabControl>

        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#DDDDDD"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True"/>

        <Canvas Grid.Column="0" x:Name="DrawCanvas" MouseLeftButtonDown="Canvas_MouseLeftButtonDown" MouseMove="Canvas_MouseMove" MouseLeftButtonUp="Canvas_MouseLeftButtonUp">
            <Canvas.Background>
                <DrawingBrush TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing>
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <LineGeometry StartPoint="0,0" EndPoint="20,0"/><LineGeometry StartPoint="0,0" EndPoint="0,20"/>
                                </GeometryGroup>
